<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:padding="20dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Mi Perfil"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginBottom="20dp"/>

        <!-- Imagen de Perfil -->
        <ImageView
            android:id="@+id/profileImage"
            android:layout_width="match_parent"
            android:layout_height="30dp"
            android:layout_marginBottom="20dp"
            android:src="@android:drawable/sym_def_app_icon" />

        <!-- Fecha de Nacimiento -->
        <EditText
            android:id="@+id/editBirthdate"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Fecha de Nacimiento (DD/MM/AAAA)"
            android:inputType="date"
            android:layout_marginBottom="15dp"/>

        <!-- Sexo (Usaremos un Spinner para opciones fijas) -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Sexo:"/>
        <Spinner
            android:id="@+id/spinnerGender"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:entries="@array/gender_options"
            android:layout_marginBottom="15dp"/>

        <!-- Profesión -->
        <EditText
            android:id="@+id/editProfession"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Profesión u Oficio"
            android:inputType="textPersonName"
            android:layout_marginBottom="15dp"/>

        <!-- Dirección -->
        <EditText
            android:id="@+id/editAddress"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="Dirección"
            android:inputType="textPostalAddress"
            android:layout_marginBottom="15dp"/>

        <!-- Social / Web -->
        <EditText
            android:id="@+id/editWeb"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:hint="URL Web o Social Media"
            android:inputType="textUri"
            android:layout_marginBottom="30dp"/>

        <Button
            android:id="@+id/btnSaveProfile"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Guardar Perfil"
            android:backgroundTint="#4CAF50"
            android:textColor="@android:color/white"/>

    </LinearLayout>
</ScrollView>